<odoo>
    <record id="view_hospital_doctor_kanban" model="ir.ui.view">
        <field name="name">hospital.doctor.kanban</field>
        <field name="model">hospital.doctor</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="phone"/>
                <field name="specialty"/>
                <field name="state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title" style="font-size: 16px;">
                                    <field name="name"/>
                                </strong>
                                <ul>
                                    <li>SĐT: <field name="phone"/></li>
                                    <li>Chuyên khoa: <field name="specialty"/></li>
                                    <li>Trạng thái: <field name="state"/></li>
                                </ul>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_hospital_doctor_tree" model="ir.ui.view">
        <field name="name">hospital.doctor.tree</field>
        <field name="model">hospital.doctor</field>
        <field name="arch" type="xml">
            <tree string="Danh sách Bác sĩ">
                <field name="name"/>
                <field name="phone"/>
                <field name="specialty"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_hospital_doctor_form" model="ir.ui.view">
        <field name="name">hospital.doctor.form</field>
        <field name="model">hospital.doctor</field>
        <field name="arch" type="xml">
            <form string="Bác sĩ">
                <header>
                    <field name="state" widget="statusbar" 
                           statusbar_visible="draft,active,inactive" 
                           options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Tên bác sĩ..."/>
                        </h1>
                    </div>
                    <notebook>
                        <page string="Thông tin cá nhân" name="personal_info">
                            <group>
                                <group>
                                    <field name="birth_year"/>
                                    <field name="age" readonly="1" invisible="not birth_year"/>
                                </group>
                                <group>
                                    <field name="phone"/>
                                </group>
                            </group>
                        </page>
                        <page string="Chuyên môn" name="professional_info">
                            <group>
                                <field name="specialty"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hospital_doctor" model="ir.actions.act_window">
        <field name="name">Bác sĩ</field>
        <field name="res_model">hospital.doctor</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>
</odoo>