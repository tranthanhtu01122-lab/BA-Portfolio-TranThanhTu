<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_borrow_request_tree" model="ir.ui.view">
        <field name="name">library.borrow.request.tree</field>
        <field name="model">library.borrow.request</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="email"/>
                <field name="book_id"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="action_borrow_request" model="ir.actions.act_window">
        <field name="name">Yêu cầu mượn sách</field>
        <field name="res_model">library.borrow.request</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_borrow_request" name="Yêu cầu mượn" parent="menu_library_root" action="action_borrow_request"/>
</odoo>